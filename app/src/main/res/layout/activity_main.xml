<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050708">

    <FrameLayout
        android:id="@+id/room_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#081012">

        <android.opengl.GLSurfaceView
            android:id="@+id/ar_surface"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:id="@+id/room_world_markers"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/carry_app_dock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#E3121718"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/browser_object"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#CC3B2C15"
            android:gravity="center"
            android:minHeight="64dp"
            android:padding="8dp"
            android:singleLine="true"
            android:text="Browser"
            android:textColor="#FFF4D7"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/social_object"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#CC1E3240"
            android:gravity="center"
            android:minHeight="64dp"
            android:padding="8dp"
            android:singleLine="true"
            android:text="Social"
            android:textColor="#E5F6FF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/calendar_object"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#CC243323"
            android:gravity="center"
            android:minHeight="64dp"
            android:padding="8dp"
            android:singleLine="true"
            android:text="Calendar"
            android:textColor="#EEFFE7"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/messages_object"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#CC362A40"
            android:gravity="center"
            android:minHeight="64dp"
            android:padding="8dp"
            android:singleLine="true"
            android:text="Messages"
            android:textColor="#F5E8FF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/settings_object"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#CC242E34"
            android:gravity="center"
            android:minHeight="64dp"
            android:padding="8dp"
            android:singleLine="true"
            android:text="Settings"
            android:textColor="#E7F4F8"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/carry_active_window"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:background="#E3121718"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/active_window_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Browser"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/active_window_close"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="X"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/active_window_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="80dp" />
    </LinearLayout>

</FrameLayout>
