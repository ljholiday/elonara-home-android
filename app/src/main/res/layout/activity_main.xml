<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050708">

    <FrameLayout
        android:id="@+id/room_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#081012">

        <android.opengl.GLSurfaceView
            android:id="@+id/ar_surface"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:id="@+id/room_world_markers"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/carry_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="2dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/carry_active_window"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#E3121718"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp"
            android:visibility="invisible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/active_window_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Browser"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/active_window_close"
                    android:layout_width="36dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="X"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/active_window_body"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:layout_weight="1"
                android:minHeight="0dp" />
        </LinearLayout>

        <Space
            android:layout_width="1dp"
            android:layout_height="6dp" />

        <LinearLayout
            android:id="@+id/carry_app_dock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/carry_dock_background"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="6dp"
            android:paddingEnd="8dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/browser_object"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/carry_dock_button_background"
                android:gravity="center"
                android:minWidth="72dp"
                android:minHeight="38dp"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:singleLine="true"
                android:text="Browser"
                android:textColor="#FFF4D7"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/social_object"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/carry_dock_button_background"
                android:gravity="center"
                android:minWidth="72dp"
                android:minHeight="38dp"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:singleLine="true"
                android:text="Social"
                android:textColor="#E5F6FF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/calendar_object"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/carry_dock_button_background"
                android:gravity="center"
                android:minWidth="72dp"
                android:minHeight="38dp"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:singleLine="true"
                android:text="Calendar"
                android:textColor="#EEFFE7"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/messages_object"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/carry_dock_button_background"
                android:gravity="center"
                android:minWidth="72dp"
                android:minHeight="38dp"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:singleLine="true"
                android:text="Messages"
                android:textColor="#F5E8FF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settings_object"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/carry_dock_button_background"
                android:gravity="center"
                android:minWidth="72dp"
                android:minHeight="38dp"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:singleLine="true"
                android:text="Settings"
                android:textColor="#E7F4F8"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
