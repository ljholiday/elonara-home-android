<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:background="#D9192326"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/roomObjectLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Room Layer"
        android:textAllCaps="true"
        android:textColor="#A9CBC4"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/roomObjectTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Calendar"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/roomObjectSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Room layer placeholder"
        android:textColor="#D0DDD5"
        android:textSize="14sp" />
</LinearLayout>
