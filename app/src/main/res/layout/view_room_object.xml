<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp">

        <View
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/room_marker_ring" />

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="center"
            android:background="@drawable/room_marker_dot" />
    </FrameLayout>

    <View
        android:layout_width="18dp"
        android:layout_height="1dp"
        android:background="@drawable/room_marker_stem" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/room_marker_label_background"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="7dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/roomObjectLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="World Marker"
            android:textAllCaps="true"
            android:textColor="#B8FFF3"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/roomObjectTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Restaurant"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/roomObjectSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="Nearby place marker"
            android:textColor="#D0DDD5"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
